        "sources",
        "deleteMergedBranches",
        "deleteMergedWorktrees",
        "strictMergedRefEquality",
        "onConflict"
      ],
      "additionalProperties": false
    },
    "git_cherry_pick_continue": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "properties": {
        "workspaceRoot": {
          "description": "Repo path. Default: first MCP root / cwd.",
          "type": "string"
        },
        "format": {
          "default": "json",
          "type": "string",
          "enum": [
            "markdown",
            "json"
          ]
        },
        "action": {
          "default": "continue",
          "description": "\"continue\" (default): resolve conflicts, stage them, then resume the sequencer. \"abort\": roll back to the pre-cherry-pick HEAD.",
          "type": "string",
          "enum": [
            "continue",
            "abort"
          ]
        }
      },
      "required": [
        "format",
        "action"
      ],
      "additionalProperties": false
    },
    "git_reset_soft": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "properties": {
        "workspaceRoot": {
          "description": "Repo path. Default: first MCP root / cwd.",
          "type": "string"
        },
        "format": {
          "default": "json",
          "type": "string",
          "enum": [
            "markdown",
            "json"
          ]
        },
        "ref": {
          "type": "string",
          "minLength": 1,
          "description": "Commit to reset to: ancestor notation (`HEAD~1`, `HEAD~3`), branch name, or SHA."
        }
      },
      "required": [
        "format",
        "ref"
      ],
      "additionalProperties": false
    },
    "git_revert": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "properties": {
        "workspaceRoot": {
          "description": "Repo path. Default: first MCP root / cwd.",
          "type": "string"
        },
        "format": {
          "default": "json",
          "type": "string",
          "enum": [
            "markdown",
            "json"
          ]
        },
        "sources": {
          "minItems": 1,
          "maxItems": 20,
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Commits to revert, applied in order: SHA, branch/tag name, or ancestor notation (`HEAD~1`)."
        },
        "noCommit": {
          "default": false,
          "description": "Pass `--no-commit`: apply the revert(s) to the index/working tree without committing (changes are left staged instead).",
          "type": "boolean"
        },
        "mainline": {
          "description": "Parent number (`-m N`) to diff against — required when reverting a merge commit.",
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        }
      },
      "required": [
        "format",
        "sources",
        "noCommit"
      ],
      "additionalProperties": false
    },
    "git_tag": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "properties": {
        "workspaceRoot": {
          "description": "Repo path. Default: first MCP root / cwd.",
          "type": "string"
        },
        "format": {
          "default": "json",
          "type": "string",
          "enum": [
            "markdown",
            "json"
          ]
        },
        "tag": {
          "type": "string",
          "minLength": 1,
          "description": "Tag name (e.g. 'v1.2.3')."
        },
        "message": {
          "description": "If provided, create an annotated tag with this message. If absent, create a lightweight tag.",
          "type": "string"
        },
        "ref": {
          "description": "Commit/ref to tag (default: HEAD). Ignored if `delete` is true.",
          "type": "string"
        },
        "delete": {
          "default": false,
          "description": "If true, delete the named tag instead of creating it.",
          "type": "boolean"
        }
      },
      "required": [
        "format",
        "tag",
        "delete"
      ],
      "additionalProperties": false
    },
    "git_branch": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "properties": {
        "workspaceRoot": {
          "description": "Repo path. Default: first MCP root / cwd.",
          "type": "string"
        },
        "format": {
          "default": "json",
          "type": "string",
          "enum": [
            "markdown",
            "json"
          ]
        },
        "action": {
          "type": "string",
          "enum": [
            "create",
            "delete",
            "rename"
          ],
          "description": "Which branch operation to perform."
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Branch name to create/delete, or the existing branch name for rename."
        },
        "from": {
          "description": "Commit-ish to base a new branch on (create only). Default: HEAD.",
          "type": "string"
        },
        "newName": {
          "description": "New branch name (required for rename).",
          "type": "string"
        },
        "force": {
          "default": false,
          "description": "Force-delete an unmerged branch (`git branch -D`). Delete only; never overrides protected-branch rejection.",
          "type": "boolean"
        }
      },
      "required": [
        "format",
        "action",
        "name",
        "force"
      ],
      "additionalProperties": false
    },
    "git_worktree_add": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "properties": {
        "workspaceRoot": {
          "description": "Repo path. Default: first MCP root / cwd.",
          "type": "string"
        },
        "format": {
          "default": "json",
          "type": "string",
          "enum": [
            "markdown",
            "json"
          ]
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "description": "Filesystem path for the new worktree (relative paths resolved from git toplevel). Sibling directories outside the repo toplevel are allowed; leading `-` and NUL are rejected."
        },
        "branch": {
          "type": "string",
          "minLength": 1,
          "description": "Branch to check out; created from `baseRef` if it doesn't exist."
        },
        "baseRef": {
          "description": "Commit-ish to base the new branch on. Default: HEAD.",
          "type": "string"
        }
      },
      "required": [
        "format",
        "path",
        "branch"
      ],
      "additionalProperties": false
    },
    "git_worktree_remove": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "properties": {
        "workspaceRoot": {
          "description": "Repo path. Default: first MCP root / cwd.",
          "type": "string"
        },
        "format": {
          "default": "json",
          "type": "string",
          "enum": [
            "markdown",
            "json"
          ]
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "description": "Path of the worktree to remove. Must not be the main worktree. Sibling paths outside the repo toplevel are allowed; leading `-` and NUL are rejected."
        },
        "force": {
          "default": false,
          "description": "Allow removal of worktrees with uncommitted changes (`--force`).",
          "type": "boolean"
        }
      },
      "required": [
        "format",
        "path",
        "force"
      ],
      "additionalProperties": false
    },
    "git_stash_apply": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "properties": {
        "workspaceRoot": {
          "description": "Repo path. Default: first MCP root / cwd.",
          "type": "string"
        },
        "format": {
          "default": "json",
          "type": "string",
          "enum": [
            "markdown",
            "json"
          ]
        },
        "index": {
          "default": 0,
          "description": "Stash index (defaults to 0 for stash@{0}).",
          "type": "integer",
          "minimum": 0,
          "maximum": 10000
        },
        "pop": {
          "default": false,
          "description": "Run `git stash pop` instead of `git stash apply` (removes stash after applying).",
          "type": "boolean"
        }
      },
      "required": [
        "format",
        "index",
        "pop"
      ],
      "additionalProperties": false
    },
    "git_stash_push": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "properties": {
        "workspaceRoot": {
          "description": "Repo path. Default: first MCP root / cwd.",
          "type": "string"
        },
        "format": {
          "default": "json",
          "type": "string",
          "enum": [
            "markdown",
            "json"
          ]
        },
        "message": {
          "description": "Stash subject message (`git stash push -m <message>`).",
          "type": "string"
        },
        "includeUntracked": {
          "default": false,
          "description": "Include untracked files in the stash (`git stash push -u`).",
          "type": "boolean"
        },
        "keepIndex": {
          "default": false,
          "description": "Keep staged changes in the index after stashing (`git stash push --keep-index`).",
          "type": "boolean"
        },
        "paths": {
          "description": "Scope the stash to specific paths, relative to git root (must resolve within repo root).",
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "format",
        "includeUntracked",
        "keepIndex"
      ],
      "additionalProperties": false
    }
  }
}
