{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "@rethunk/mcp-multi-root-git: git_status",
  "description": "Parameter schema for the 'git_status' MCP tool.",
  "type": "object",
  "properties": {
    "root": {
      "description": "Repo path, array of paths, or \"*\" for all MCP roots.",
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      ]
    },
    "format": {
      "default": "json",
      "type": "string",
      "enum": [
        "markdown",
        "json"
      ]
    },
    "includeSubmodules": {
      "default": true,
      "type": "boolean"
    }
  },
  "required": [
    "format",
    "includeSubmodules"
  ],
  "additionalProperties": false
}
