{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "@rethunk/mcp-multi-root-git: git_stash_apply",
  "description": "Parameter schema for the 'git_stash_apply' MCP tool.",
  "type": "object",
  "properties": {
    "workspaceRoot": {
      "description": "Highest-priority root override.",
      "type": "string"
    },
    "rootIndex": {
      "description": "0-based index into MCP roots; ignored if workspaceRoot set.",
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "format": {
      "default": "markdown",
      "type": "string",
      "enum": [
        "markdown",
        "json"
      ]
    },
    "index": {
      "default": 0,
      "description": "Stash index (defaults to 0 for stash@{0}).",
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "pop": {
      "default": false,
      "description": "Run `git stash pop` instead of `git stash apply` (removes stash after applying).",
      "type": "boolean"
    }
  },
  "required": [
    "format",
    "index",
    "pop"
  ],
  "additionalProperties": false
}
