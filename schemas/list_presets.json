{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "@rethunk/mcp-multi-root-git: list_presets",
  "description": "Parameter schema for the 'list_presets' MCP tool.",
  "type": "object",
  "properties": {
    "root": {
      "description": "Repo path, array of paths, or \"*\" for all MCP roots.",
      "anyOf": [
        {
          "type": "string"
        },
        {
          "maxItems": 256,
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        {
          "type": "string",
          "const": "*"
        }
      ]
    },
    "format": {
      "default": "markdown",
      "type": "string",
      "enum": [
        "markdown",
        "json"
      ]
    }
  },
  "required": [
    "format"
  ],
  "additionalProperties": false
}
