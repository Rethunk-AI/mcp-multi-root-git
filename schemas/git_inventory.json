{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "@rethunk/mcp-multi-root-git: git_inventory",
  "description": "Parameter schema for the 'git_inventory' MCP tool.",
  "type": "object",
  "properties": {
    "root": {
      "description": "Repo path, array of paths, or \"*\" for all MCP roots.",
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      ]
    },
    "format": {
      "default": "markdown",
      "type": "string",
      "enum": [
        "markdown",
        "json"
      ]
    },
    "nestedRoots": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "preset": {
      "type": "string"
    },
    "presetMerge": {
      "default": false,
      "description": "Merge with preset instead of replacing.",
      "type": "boolean"
    },
    "remote": {
      "description": "Pair with `branch`.",
      "type": "string"
    },
    "branch": {
      "description": "Pair with `remote`.",
      "type": "string"
    },
    "compareRefs": {
      "description": "Ahead/behind between two local refs (e.g. main vs a feature branch), independent of upstream tracking.",
      "type": "object",
      "properties": {
        "left": {
          "type": "string",
          "description": "Base ref (ahead = commits in right not in left)."
        },
        "right": {
          "type": "string",
          "description": "Other ref (behind = commits in left not in right)."
        }
      },
      "required": [
        "left",
        "right"
      ],
      "additionalProperties": false
    },
    "maxRoots": {
      "default": 64,
      "type": "integer",
      "minimum": 1,
      "maximum": 256
    }
  },
  "required": [
    "format",
    "presetMerge",
    "maxRoots"
  ],
  "additionalProperties": false
}
