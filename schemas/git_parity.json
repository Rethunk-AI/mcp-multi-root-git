{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "@rethunk/mcp-multi-root-git: git_parity",
  "description": "Parameter schema for the 'git_parity' MCP tool.",
  "type": "object",
  "properties": {
    "root": {
      "description": "Repo path, array of paths, or \"*\" for all MCP roots.",
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      ]
    },
    "format": {
      "default": "markdown",
      "type": "string",
      "enum": [
        "markdown",
        "json"
      ]
    },
    "pairs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "left": {
            "type": "string"
          },
          "right": {
            "type": "string"
          },
          "label": {
            "type": "string"
          }
        },
        "required": [
          "left",
          "right"
        ],
        "additionalProperties": false
      }
    },
    "preset": {
      "type": "string"
    },
    "presetMerge": {
      "default": false,
      "type": "boolean"
    }
  },
  "required": [
    "format",
    "presetMerge"
  ],
  "additionalProperties": false
}
